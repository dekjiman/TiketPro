{
  "name": "tiketpro",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd apps/api && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "build": "npm --prefix apps/api run build && npm --prefix apps/web run build",
    "db:push": "npm --prefix apps/api run db:push",
    "db:seed": "npm --prefix apps/api run db:seed"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@fastify/rate-limit": "^9.1.0",
    "@hookform/resolvers": "^5.2.2",
    "jose": "^6.2.2",
    "react-hook-form": "^7.73.1",
    "sonner": "^2.0.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
